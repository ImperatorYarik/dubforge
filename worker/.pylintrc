[MASTER]
# Add worker/ to sys.path so app.* imports resolve correctly
init-hook='import sys; sys.path.insert(0, ".")'

# Suppress import-error for GPU/ML packages unavailable in the lint CI environment.
# These packages require CUDA or heavy optional dependencies (torch, ctranslate2, etc.)
# and are only present at runtime on the GPU worker container.
ignored-modules=
    torch,
    torchaudio,
    faster_whisper,
    TTS,
    demucs,
    soundfile,
    numpy,
    transformers,
    ffmpeg

[MESSAGES CONTROL]
# Disable convention (C) and refactoring (R) categories — too noisy for CI hooks.
# Keep errors (E) and warnings (W) with a few targeted suppressions below.
disable=
    C,
    R,
    W0511,  # fixme — TODO comments are tracked in issues, not lint
    W1203,  # logging-fstring-interpolation — f-strings in logging are acceptable here
    E0401,  # import-error — GPU/ML packages not installed in lint environment

[FORMAT]
max-line-length=120
